<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="20dp"
        android:paddingBottom="24dp">

        <!-- Screen title -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Parcel Requests"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="@color/text_primary"
            android:layout_marginBottom="4dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Accept or decline within 20 seconds"
            android:textSize="13sp"
            android:textColor="@color/text_secondary"
            android:layout_marginBottom="20dp" />

        <!-- ═══════════════════════════════════════════
             REQUEST ONE
             ═══════════════════════════════════════════ -->
        <LinearLayout
            android:id="@+id/requestOneGroup"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_request_card"
            android:padding="20dp"
            android:layout_marginBottom="8dp">

            <!-- Top row: fare + countdown ring -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="14dp">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_centerVertical="true">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="PAYOUT"
                        android:textSize="@dimen/text_label"
                        android:textColor="@color/text_secondary"
                        android:textStyle="bold"
                        android:letterSpacing="0.12" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="R 180"
                        android:textSize="@dimen/text_display"
                        android:textStyle="bold"
                        android:textColor="@color/accent" />
                </LinearLayout>

                <!-- Countdown ring -->
                <FrameLayout
                    android:layout_width="@dimen/countdown_size"
                    android:layout_height="@dimen/countdown_size"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true">

                    <com.google.android.material.progressindicator.CircularProgressIndicator
                        android:id="@+id/pb_countdown_one"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:indeterminate="false"
                        android:progress="100"
                        android:max="100"
                        app:indicatorColor="@color/accent"
                        app:trackColor="#2A2A2A"
                        app:indicatorSize="56dp"
                        app:trackThickness="4dp" />

                    <TextView
                        android:id="@+id/tv_countdown_one"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:gravity="center"
                        android:text="20"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="@color/text_primary" />
                </FrameLayout>
            </RelativeLayout>

            <!-- Route info -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/divider"
                android:layout_marginBottom="14dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ROUTE"
                android:textSize="@dimen/text_label"
                android:textColor="@color/text_secondary"
                android:textStyle="bold"
                android:letterSpacing="0.12"
                android:layout_marginBottom="6dp" />

            <TextView
                android:id="@+id/tv_request_one"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Sandton → Rosebank  •  18:30  •  R 180"
                android:textSize="15sp"
                android:textColor="@color/text_primary"
                android:lineSpacingMultiplier="1.3"
                android:layout_marginBottom="18dp" />

            <!-- Accept + Decline -->
            <Button
                android:id="@+id/btn_accept_one"
                style="@style/Btn.Accept"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="ACCEPT"
                android:layout_marginBottom="8dp" />

            <Button
                android:id="@+id/btn_decline_one"
                style="@style/Btn.Decline"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Decline" />
        </LinearLayout>

        <!-- Trip 1: status shown after decision -->
        <TextView
            android:id="@+id/tv_status_one"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:visibility="gone"
            android:textSize="14sp"
            android:textColor="@color/text_secondary"
            android:textStyle="italic"
            android:paddingTop="8dp"
            android:paddingBottom="4dp" />

        <!-- Trip 1: actions after accept -->
        <LinearLayout
            android:id="@+id/trip_one_actions"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone"
            android:layout_marginBottom="16dp">

            <Button
                android:id="@+id/btn_start_trip_one"
                style="@style/Btn.Primary"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Start Trip"
                android:layout_marginBottom="8dp" />

            <Button
                android:id="@+id/btn_board_passenger_one"
                style="@style/Btn.Outline"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Parcel On Board"
                android:layout_marginBottom="8dp" />

            <Button
                android:id="@+id/btn_complete_trip_one"
                style="@style/Btn.Action"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Complete Delivery" />
        </LinearLayout>

        <!-- ═══════════════════════════════════════════
             REQUEST TWO
             ═══════════════════════════════════════════ -->
        <LinearLayout
            android:id="@+id/request_two_group"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_request_card"
            android:padding="20dp"
            android:layout_marginBottom="8dp">

            <!-- Top row: fare + countdown ring -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="14dp">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_centerVertical="true">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="PAYOUT"
                        android:textSize="@dimen/text_label"
                        android:textColor="@color/text_secondary"
                        android:textStyle="bold"
                        android:letterSpacing="0.12" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="R 95"
                        android:textSize="@dimen/text_display"
                        android:textStyle="bold"
                        android:textColor="@color/accent" />
                </LinearLayout>

                <!-- Countdown ring -->
                <FrameLayout
                    android:layout_width="@dimen/countdown_size"
                    android:layout_height="@dimen/countdown_size"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true">

                    <com.google.android.material.progressindicator.CircularProgressIndicator
                        android:id="@+id/pb_countdown_two"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:indeterminate="false"
                        android:progress="100"
                        android:max="100"
                        app:indicatorColor="@color/accent"
                        app:trackColor="#2A2A2A"
                        app:indicatorSize="56dp"
                        app:trackThickness="4dp" />

                    <TextView
                        android:id="@+id/tv_countdown_two"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:gravity="center"
                        android:text="20"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="@color/text_primary" />
                </FrameLayout>
            </RelativeLayout>

            <!-- Route info -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/divider"
                android:layout_marginBottom="14dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ROUTE"
                android:textSize="@dimen/text_label"
                android:textColor="@color/text_secondary"
                android:textStyle="bold"
                android:letterSpacing="0.12"
                android:layout_marginBottom="6dp" />

            <TextView
                android:id="@+id/tv_request_two"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Midrand → Pretoria  •  20:00  •  R 95"
                android:textSize="15sp"
                android:textColor="@color/text_primary"
                android:lineSpacingMultiplier="1.3"
                android:layout_marginBottom="18dp" />

            <!-- Accept + Decline -->
            <Button
                android:id="@+id/btn_accept_two"
                style="@style/Btn.Accept"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="ACCEPT"
                android:layout_marginBottom="8dp" />

            <Button
                android:id="@+id/btn_decline_two"
                style="@style/Btn.Decline"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Decline" />
        </LinearLayout>

        <!-- Trip 2: status shown after decision -->
        <TextView
            android:id="@+id/tv_status_two"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:visibility="gone"
            android:textSize="14sp"
            android:textColor="@color/text_secondary"
            android:textStyle="italic"
            android:paddingTop="8dp"
            android:paddingBottom="4dp" />

        <!-- Trip 2: actions after accept -->
        <LinearLayout
            android:id="@+id/trip_two_actions"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone">

            <Button
                android:id="@+id/btn_start_trip_two"
                style="@style/Btn.Primary"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Start Trip"
                android:layout_marginBottom="8dp" />

            <Button
                android:id="@+id/btn_board_passenger_two"
                style="@style/Btn.Outline"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Parcel On Board"
                android:layout_marginBottom="8dp" />

            <Button
                android:id="@+id/btn_complete_trip_two"
                style="@style/Btn.Action"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Complete Delivery" />
        </LinearLayout>

    </LinearLayout>
</ScrollView>
