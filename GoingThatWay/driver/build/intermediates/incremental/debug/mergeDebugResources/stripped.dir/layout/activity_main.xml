<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp">

    <TextView
        android:id="@+id/tv_welcome"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Welcome Driver"
        android:textSize="22sp"
        android:textStyle="bold"
        android:layout_marginBottom="16dp" />

    <TextView
        android:id="@+id/tv_status"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="You are online and ready to take new trip requests."
        android:textStyle="bold"
        android:layout_marginBottom="24dp" />

    <Button
        android:id="@+id/btn_post_trip"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/post_trip"
        android:layout_marginBottom="12dp" />

    <Button
        android:id="@+id/btn_my_trips"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/my_trips"
        android:layout_marginBottom="12dp" />

    <Button
        android:id="@+id/btn_profile"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Profile"
        android:layout_marginBottom="12dp" />

    <Button
        android:id="@+id/btn_earnings"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Earnings"
        android:layout_marginBottom="12dp" />

    <Button
        android:id="@+id/btn_support"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Support"
        android:layout_marginBottom="12dp" />

    <Button
        android:id="@+id/btn_trip_requests"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Trip Requests" />
</LinearLayout>
