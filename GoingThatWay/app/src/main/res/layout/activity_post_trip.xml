<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/white">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/primary"
        app:title="Post My Trip"
        app:titleTextColor="@color/white"
        app:navigationIcon="@drawable/ic_arrow_back" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- Route section -->
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Your Route"
                android:textSize="14sp" android:textStyle="bold"
                android:textColor="@color/text_secondary"
                android:layout_marginBottom="10dp" android:layout_marginTop="4dp" />

            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:hint="From (Origin)"
                style="@style/GtwInput" android:layout_marginBottom="12dp">
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/et_origin_address"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:inputType="textPostalAddress|textCapWords" />
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:hint="To (Destination)"
                style="@style/GtwInput" android:layout_marginBottom="12dp">
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/et_destination_address"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:inputType="textPostalAddress|textCapWords" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Timing section -->
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Timing"
                android:textSize="14sp" android:textStyle="bold"
                android:textColor="@color/text_secondary"
                android:layout_marginBottom="10dp" android:layout_marginTop="8dp" />

            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:hint="Departure Date &amp; Time (e.g. 2025-08-15 09:00)"
                style="@style/GtwInput" android:layout_marginBottom="12dp">
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/et_departure_time"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:inputType="datetime" android:focusable="true"
                    android:clickable="true" />
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:hint="Arrival Date &amp; Time (optional)"
                style="@style/GtwInput" android:layout_marginBottom="12dp">
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/et_arrival_time"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:inputType="datetime" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Travel details -->
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Travel Details"
                android:textSize="14sp" android:textStyle="bold"
                android:textColor="@color/text_secondary"
                android:layout_marginBottom="10dp" android:layout_marginTop="8dp" />

            <Spinner android:id="@+id/spinner_transport_mode"
                android:layout_width="match_parent" android:layout_height="56dp"
                android:background="@android:drawable/btn_dropdown"
                android:layout_marginBottom="12dp" />

            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:hint="Available capacity (kg)"
                style="@style/GtwInput" android:layout_marginBottom="12dp">
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/et_capacity_kg"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:inputType="numberDecimal" />
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:hint="Notes (optional)"
                style="@style/GtwInput" android:layout_marginBottom="24dp">
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/et_notes"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:inputType="textMultiLine" android:lines="2" />
            </com.google.android.material.textfield.TextInputLayout>

            <ProgressBar android:id="@+id/progress_bar"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:layout_gravity="center" android:visibility="gone"
                android:indeterminateTint="@color/primary" android:layout_marginBottom="8dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_post_trip"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:text="Post Trip"
                android:textSize="16sp"
                style="@style/Btn.Primary" />

        </LinearLayout>
    </ScrollView>
</LinearLayout>
