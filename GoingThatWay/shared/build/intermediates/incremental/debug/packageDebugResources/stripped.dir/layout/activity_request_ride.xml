<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/white">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/primary"
        app:title="Book a Ride"
        app:titleTextColor="@color/white"
        app:navigationIcon="@drawable/ic_arrow_back" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- On-Demand button (prominent) -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_request_ride_now"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="📍 Request Ride Now (use my GPS location)"
                android:textSize="15sp"
                android:layout_marginBottom="20dp"
                style="@style/Btn.Action" />

            <View android:layout_width="match_parent" android:layout_height="1dp"
                android:background="@color/divider" android:layout_marginBottom="20dp" />

            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="— or schedule a ride —"
                android:textSize="13sp" android:textColor="@color/text_secondary"
                android:layout_gravity="center" android:layout_marginBottom="16dp" />

            <!-- Section: Ride Details -->
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Ride Details"
                android:textSize="14sp" android:textStyle="bold"
                android:textColor="@color/text_secondary"
                android:layout_marginBottom="10dp" android:layout_marginTop="4dp" />

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:layout_marginBottom="12dp">
                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:hint="Passengers"
                    style="@style/GtwInput" android:layout_marginEnd="8dp">
                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/et_passenger_count"
                        android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:inputType="number" />
                </com.google.android.material.textfield.TextInputLayout>

                <Spinner android:id="@+id/spinner_luggage_size"
                    android:layout_width="0dp" android:layout_height="56dp"
                    android:layout_weight="1"
                    android:background="@android:drawable/btn_dropdown" />
            </LinearLayout>

            <!-- Section: Route -->
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Route"
                android:textSize="14sp" android:textStyle="bold"
                android:textColor="@color/text_secondary"
                android:layout_marginBottom="10dp" android:layout_marginTop="4dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="8dp">
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_pin_pickup"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Pin pickup" />
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_pin_destination"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Pin destination" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="12dp">
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_use_current_location"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Use current" />
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_geo_pickup"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Lookup pickup" />
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_geo_destination"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Lookup dest" />
            </LinearLayout>

            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:hint="Pickup Address (scheduled ride)"
                style="@style/GtwInput" android:layout_marginBottom="12dp">
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/et_pickup_address"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:inputType="textPostalAddress|textCapWords" />
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:hint="Destination Address"
                style="@style/GtwInput" android:layout_marginBottom="12dp">
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/et_destination_address"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:inputType="textPostalAddress|textCapWords" />
            </com.google.android.material.textfield.TextInputLayout>

            <org.osmdroid.views.MapView
                android:id="@+id/map_view"
                android:layout_width="match_parent"
                android:layout_height="220dp"
                android:layout_marginBottom="16dp" />

            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:hint="Notes (optional)"
                style="@style/GtwInput" android:layout_marginBottom="8dp">
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/et_notes"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:inputType="textMultiLine" android:lines="2" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Fare preview -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/tv_fare_breakdown"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="20dp"
                android:visibility="gone"
                app:cardCornerRadius="10dp"
                app:cardBackgroundColor="@color/primary_light">
                <TextView
                    android:id="@+id/tv_fare_text"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textSize="13sp"
                    android:textColor="@color/primary_dark"
                    android:padding="14dp" />
            </com.google.android.material.card.MaterialCardView>

            <ProgressBar android:id="@+id/progress_bar"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:layout_gravity="center" android:visibility="gone"
                android:indeterminateTint="@color/primary" android:layout_marginBottom="8dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_proceed_to_payment"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:text="Schedule Ride — Proceed to Payment"
                android:textSize="15sp"
                style="@style/Btn.Action" />

        </LinearLayout>
    </ScrollView>
</LinearLayout>
